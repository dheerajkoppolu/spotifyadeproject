			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "spotify-adf-service"
		},
		"AzureDataLakeStorage_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage'"
		},
		"AzureSQLDB_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSQLDB'"
		},
		"AzureDataLakeStorage_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://spotifyadlsaccount.dfs.core.windows.net/"
		},
		"AzureSQLDB_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "spotifyserver2026.database.windows.net"
		},
		"AzureSQLDB_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "spotify"
		},
		"AzureSQLDB_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Azureuser"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
