							"source": {
								"type": "AzureSqlSource",
								"sqlReaderQuery": {
									"value": "select * from @{pipeline().parameters.schema}.@{pipeline().parameters.table}\nwhere @{pipeline().parameters.cdc_col} > '@{if(empty(pipeline().parameters.fromDate),\n    activity('LookupCDC').output.value[0].cdc,\n    pipeline().parameters.fromDate)}'",
